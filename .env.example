# NinjaClaw — example environment configuration.
# Copy to `.env` and fill in the values you actually use. All keys are optional;
# unset channels stay disabled.

# ---------------------------------------------------------------------------
# Core assistant
# ---------------------------------------------------------------------------
ASSISTANT_NAME=Andy
# ASSISTANT_HAS_OWN_NUMBER=false
# TZ=UTC

# ---------------------------------------------------------------------------
# OneCLI credential gateway (per-group model auth)
# ---------------------------------------------------------------------------
# ONECLI_URL=http://localhost:8080
# ONECLI_API_KEY=

# ---------------------------------------------------------------------------
# Telegram channel
# ---------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Microsoft Teams channel (legacy Bot Framework)
# ---------------------------------------------------------------------------
# TEAMS_BOT_APP_ID=
# TEAMS_BOT_APP_PASSWORD=
# TEAMS_BOT_TENANT_ID=
# TEAMS_BOT_PORT=3978

# ---------------------------------------------------------------------------
# Microsoft Agent 365 channel (preview, opt-in)
# ---------------------------------------------------------------------------
# Entra Agent ID app registration. Leave AGENT365_CLIENT_ID empty to keep
# the channel disabled. Requires a Frontier-enabled Microsoft 365 tenant.
# Run scripts/agent365/provision.sh to populate these automatically.
# AGENT365_CLIENT_ID=
# AGENT365_TENANT_ID=
# AGENT365_CLIENT_SECRET=
# AGENT365_OBJECT_ID=
# AGENT365_PORT=3979

# Optional override for the Agent 365 observability ingestion endpoint.
# AGENT365_OBSERVABILITY_ENDPOINT=

# Direct Microsoft Graph fallback for OBO calls when the admin tenant has
# not curated an MCP server covering the requested workload. Off by default
# so admin-curated MCP policy stays the canonical control plane.
# AGENT365_GRAPH_FALLBACK=false

# ---------------------------------------------------------------------------
# Agent 365 admin console (Web UI sign-in)
# ---------------------------------------------------------------------------
# OAuth client used by the Web UI's "Sign in with Microsoft" flow. Defaults
# to the public Azure CLI app id, which already has user_impersonation for
# Graph + ARM. Override once you've registered a dedicated admin console app.
# AGENT365_ADMIN_CLIENT_ID=
# AGENT365_ADMIN_TENANT=organizations
# AGENT365_ADMIN_SCOPES=https://agent365.svc.cloud.microsoft/.default,https://management.azure.com/user_impersonation,https://graph.microsoft.com/Application.ReadWrite.All

# Blueprint id assigned by the admin plane after a successful publish.
# Auto-populated by the Web UI on success; safe to leave empty.
# AGENT365_BLUEPRINT_ID=

# ---------------------------------------------------------------------------
# Agent 365 hosting + admin-center publish (Phase 3, set by provision.sh)
# ---------------------------------------------------------------------------
# Hosting mode (bot-framework | tailscale). Set automatically by the
# matching 02-*.sh script.
# AGENT365_HOSTING_MODE=

# Public HTTPS URL of /api/messages on this host. M365 cloud (or Bot
# Framework relay) posts inbound activities here.
# AGENT365_MESSAGING_ENDPOINT=

# Bot Framework mode only.
# AGENT365_BOT_NAME=

# Tailscale mode only.
# AGENT365_TAILSCALE_FQDN=

# Blueprint publish API (internal preview endpoint — confirm with Microsoft
# Frontier program contact before flipping --apply).
# AGENT365_PUBLISH_API=https://agent365.svc.cloud.microsoft/admin/v1/blueprints
# AGENT365_PUBLISH_AUDIENCE=https://agent365.svc.cloud.microsoft/.default

# ---------------------------------------------------------------------------
# Container runtime
# ---------------------------------------------------------------------------
# CONTAINER_IMAGE=ninjaclaw-agent:latest
# CONTAINER_TIMEOUT=1800000
# IDLE_TIMEOUT=1800000
# MAX_CONCURRENT_CONTAINERS=5
# MAX_MESSAGES_PER_PROMPT=10
